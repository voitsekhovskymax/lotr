{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Vintage Story (Default)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "D:\\games\\VintageStory\\PlayVintageStory.exe",
            "args": [],
            "cwd": "D:\\games\\VintageStory",
            "stopAtEntry": false,
            "console": "internalConsole"
        },
        {
            "name": "Launch Vintage Story (Select World)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "D:\\games\\VintageStory\\PlayVintageStory.exe",
            "args": [
                "--openWorld=${input:worldName}"
            ],
            "cwd": "D:\\games\\VintageStory",
            "stopAtEntry": false,
            "console": "internalConsole"
        },
        {
            "name": "Attach to Vintage Story",
            "type": "coreclr",
            "request": "attach",
            "processName": "Vintagestory"
        }
    ],
    "inputs": [
        {
            "id": "worldName",
            "type": "promptString",
            "description": "Enter the world name to auto-load (e.g. TestWorld)",
            "default": "TestWorld"
        }
    ]
}